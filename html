<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Travel & Dine Experience</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="#">EVASION & GOURMET</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#menu">Menu</a></li>
                    <li class="nav-item"><a class="nav-link" href="#destinations">Destinations</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">About Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <header id="home" class="hero-section d-flex align-items-center text-center text-white">
        <div class="container">
            <h1 class="display-2 fw-bold">Voyagez par les Sens</h1>
            <p class="lead">Des destinations de rêve et une cuisine d'exception.</p>
            <a href="#destinations" class="btn btn-primary btn-lg px-4 me-sm-3">Découvrir</a>
        </div>
    </header>

    <section id="menu" class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Notre Menu Signature</h2>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500" class="card-img-top" alt="Salade">
                        <div class="card-body">
                            <h5 class="card-title">Salade Méditerranéenne</h5>
                            <p class="card-text text-muted">Légumes frais, feta et olives de Grèce.</p>
                            <span class="badge bg-success">14,00 €</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1513104890138-7c749659a591?w=500" class="card-img-top" alt="Pizza">
                        <div class="card-body">
                            <h5 class="card-title">Pizza Artisanale</h5>
                            <p class="card-text text-muted">Cuite au feu de bois, mozzarella di bufala.</p>
                            <span class="badge bg-success">18,00 €</span>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 shadow-sm">
                        <img src="https://images.unsplash.com/photo-1551024601-bec78aea704b?w=500" class="card-img-top" alt="Dessert">
                        <div class="card-body">
                            <h5 class="card-title">Délice au Chocolat</h5>
                            <p class="card-text text-muted">Fondant noir 70% et sa glace vanille.</p>
                            <span class="badge bg-success">9,00 €</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="py-5 bg-light">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <img src="https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=600" class="img-fluid rounded shadow" alt="Restaurant">
                </div>
                <div class="col-md-6">
                    <h2 class="mt-4 mt-md-0">Notre Histoire</h2>
                    <p class="text-muted mt-3">Depuis 2010, nous combinons l'amour de la gastronomie et la passion du voyage pour vous offrir des moments inoubliables. Chaque plat raconte une histoire, chaque destination est une promesse d'évasion.</p>
                    <button class="btn btn-outline-dark">En savoir plus</button>
                </div>
            </div>
        </div>
    </section>

    <section id="destinations" class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Destinations de Rêve</h2>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="card bg-dark text-white border-0 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1506929562872-bb421503ef21?w=500" class="card-img opacity-75" alt="Plage">
                        <div class="card-img-overlay d-flex flex-column justify-content-end">
                            <h5 class="card-title">Maldives</h5>
                            <p class="card-text small">Eaux turquoise et sable blanc.</p>
                            <a href="#" class="btn btn-sm btn-light">Learn More</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card bg-dark text-white border-0 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1493246507139-91e8fad9978e?w=500" class="card-img opacity-75" alt="Montagne">
                        <div class="card-img-overlay d-flex flex-column justify-content-end">
                            <h5 class="card-title">Alpes Suisses</h5>
                            <p class="card-text small">Sommets enneigés et air pur.</p>
                            <a href="#" class="btn btn-sm btn-light">Learn More</a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card bg-dark text-white border-0 overflow-hidden">
                        <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=500" class="card-img opacity-75" alt="Nature">
                        <div class="card-img-overlay d-flex flex-column justify-content-end">
                            <h5 class="card-title">Islande</h5>
                            <p class="card-text small">Aurores boréales et geysers.</p>
                            <a href="#" class="btn btn-sm btn-light">Learn More</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="tours" class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5">Nos Formules Circuits</h2>
            <div class="accordion shadow-sm" id="accordionTours">
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#tour1">
                            Circuit Gourmet - 7 Jours
                        </button>
                    </h2>
                    <div id="tour1" class="accordion-collapse collapse show" data-bs-parent="#accordionTours">
                        <div class="accordion-body">
                            Découvrez les meilleures tables de France avec des dégustations privées. <strong>Inclus : Vols, Hôtels 5* et Repas.</strong> <br>
                            <a href="#" class="btn btn-link p-0 mt-2">View Details</a>
                        </div>
                    </div>
                </div>
                <div class="accordion-item">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#tour2">
                            Aventure Tropicale - 10 Jours
                        </button>
                    </h2>
                    <div id="tour2" class="accordion-collapse collapse" data-bs-parent="#accordionTours">
                        <div class="accordion-body">
                            Randonnée en jungle et plongée sous-marine. Idéal pour les sportifs. <br>
                            <a href="#" class="btn btn-link p-0 mt-2">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="contact" class="py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <div class="card shadow p-4 border-0">
                        <h2 class="text-center mb-4">Contactez-nous</h2>
                        <form>
                            <div class="mb-3">
                                <label class="form-label">Nom Complet</label>
                                <input type="text" class="form-control" placeholder="Sophia Boucharif">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" class="form-control" placeholder="nom@exemple.com">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Destination souhaitée</label>
                                <select class="form-select">
                                    <option>Maldives</option>
                                    <option>Alpes</option>
                                    <option>Islande</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Message</label>
                                <textarea class="form-control" rows="4"></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Envoyer le message</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-2">&copy; 2026 EVASION & GOURMET. Tous droits réservés.</p>
            <div class="h3">
                <i class="fa-brands fa-facebook-f mx-2 cursor-pointer"></i>
                <i class="fa-brands fa-instagram mx-2"></i>
                <i class="fa-brands fa-twitter mx-2"></i>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
